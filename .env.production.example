# Easylook Website production deploy config
# 这份文件是 GitHub Actions production environment 的唯一配置源。
# 执行 `bash scripts/sync-github-production-env.sh` 后，会自动同步到 GitHub。

# OVO Server 根地址。
# 作用：
# - workflow 安装 ovo-ci 时作为 --server
# - ovo-ci publish 时作为 server API 入口
# 示例：
# - 根路径部署: https://ovo.example.com
# - 子路径部署: https://deploy.example.com/ovo-server
OVO_SERVER_URL=https://ovo.example.com

# OVO deploy token。
# 作用：
# - 下载 install/ovo-ci.sh
# - 调用 ovo-ci publish 把 bundle 发布到指定 client/service
# 建议：
# - 视为敏感信息，只放在 .env.production 和 GitHub Secret 中
OVO_DEPLOY_TOKEN=replace-with-real-deploy-token

# 目标 client ID。
# 作用：
# - 指定这次发布下发到哪一台 client
# - workflow 会同步成 GitHub Variable: OVO_TARGET_CLIENT_ID
OVO_TARGET_CLIENT_ID=replace-with-client-id

# 目标 service ID。
# 作用：
# - 指定这次发布对应哪一个 OVO service
# - workflow 会同步成 GitHub Variable: OVO_SERVICE_ID
OVO_SERVICE_ID=replace-with-service-id

# 站点对外访问的基础路径，同时也会传给前端构建阶段的 PUBLIC_URL。
# 常见值：
# - 根路径部署: /
# - 子路径部署: /easylook-website/
# 影响：
# - 静态资源前缀
# - bundle metadata 中的 base_path
# - 默认 healthcheck URL 推导
OVO_PUBLIC_URL=/

# client 上部署静态文件的目标目录。
# deploy.sh 会把 bundle 中的 runtime/public 同步到这个目录。
# 影响：
# - 发布落盘路径
# - status / healthcheck 的 filesystem_ready 判定
OVO_DEPLOY_TARGET_ROOT=/var/www/easylook-website/build

# 发布完成后的健康检查地址。
# 要求：
# - 返回 HTTP 200 才算部署成功
# - 建议使用 client 本机可访问的地址，而不是依赖公网 DNS 的地址
# 常见值：
# - 根路径部署: http://localhost/
# - 子路径部署: http://localhost/easylook-website/
OVO_HEALTHCHECK_URL=http://localhost/

# 健康检查等待秒数。
# 作用：
# - deploy.sh 在同步静态文件后最多等待多少秒让站点返回 HTTP 200
# - 适合首屏资源多、nginx reload 较慢、CDN/代理切换需要一点时间的站点
OVO_HEALTHCHECK_TIMEOUT=30
